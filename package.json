{
  "name": "ucm-desktop-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "UCM WebRTC softphone desktop client",
  "author": "UCM Desktop Client",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "npx @electron/rebuild -f -w better-sqlite3 && patch-package",
    "dist": "npm run build && electron-builder --config electron-builder.config.js",
    "dist:mac": "npm run build && electron-builder --config electron-builder.config.js --mac",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.js --win --x64",
    "dist:all": "npm run build && electron-builder --config electron-builder.config.js --mac --win --x64"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "sip.js": "^0.21.2",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.1"
  }
}
